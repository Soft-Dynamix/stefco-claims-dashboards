generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InsuranceCompany {
  id               String  @id @default(cuid())
  name             String
  folderName       String  @unique
  senderDomains    String  // JSON array of domains
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  claims           Claim[]
  learningPatterns LearningPattern[]
  senderPatterns   SenderPattern[]
}

model Claim {
  id                  String   @id @default(cuid())
  claimNumber         String   @unique
  clientName          String
  insuranceCompanyId  String?
  insuranceCompany    InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  claimType           String   // Motor, Building, Marine, Agricultural, Household, Liability
  status              String   @default("NEW") // NEW, PROCESSING, COMPLETED, MANUAL_REVIEW, FAILED, PENDING_REVIEW
  senderEmail         String?
  emailSubject        String?
  contactNumber       String?
  contactEmail        String?
  incidentDescription String?
  excessAmount        String?
  specialInstructions String?
  folderPath          String?
  vehicleMake         String?
  vehicleModel        String?
  vehicleYear         String?
  vehicleRegistration String?
  propertyAddress     String?
  attachmentsCount    Int      @default(0)
  documentsPrinted    Boolean  @default(false)
  confidenceScore     Int      @default(0)
  aiClassification    String?  // NEW_CLAIM, IGNORE, MISSING_INFO, OTHER
  aiClassificationConfidence Int @default(0)
  processingStage     String   @default("RECEIVED") // RECEIVED, CLASSIFIED, EXTRACTED, FOLDER_CREATED, DOCUMENTS_SAVED, PRINTED, LOGGED, RESPONDED
  needsAttention      Boolean  @default(false) // Flagged for low confidence or user-flagged issues
  verifiedByUser      Boolean  @default(false) // User has confirmed data is correct
  reviewedAt          DateTime? // When the user reviewed this claim
  reviewAction        String?  // "accepted", "corrected", "flagged_for_review", "skipped"
  aiHintsUsed         String?  // JSON: list of learning hints applied during extraction
  // Multi-Agent System fields
  aiDecision          String?  // "auto_classify", "needs_review", "manual_review"
  aiReasoning         String?  // AI's reasoning for classification
  aiConfidenceBreakdown String? // JSON: { classification: 85, extraction: 72, overall: 77 }
  aiAlternatives      String?  // JSON: [{ class: "Motor", score: 0.7 }, ...]
  notes               String?
  processedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  auditLogs           AuditLog[]
  printQueueItems     PrintQueueItem[]
  feedback            ClaimFeedback[]
  predictions         Prediction[]
  extractedEntities   ExtractedEntity[]
  knowledgeEntries    ClassificationKnowledge[]
}

// ─── Multi-Agent Prediction System ────────────────────────────────────────────
// Stores full AI predictions with alternatives, reasoning, and decision routing.
// Each claim can have one prediction record tracking the classification agent's output.

model Prediction {
  id                  String   @id @default(cuid())
  claimId             String
  claim               Claim    @relation(fields: [claimId], references: [id])
  predictedClass      String   // "NEW_CLAIM", "IGNORE", "MISSING_INFO", "OTHER"
  confidence          Float    // 0.0 to 1.0
  alternatives        String   // JSON: [{ class: "New Claim", score: 0.7 }, ...]
  reasoning           String?  // AI's explanation for the classification
  decision            String   // "auto_classify", "needs_review", "manual_review"
  decisionReasoning   String?  // Why the decision engine chose this action
  learningHintsCount  Int      @default(0) // How many learning patterns were injected
  createdAt           DateTime @default(now())
}

// ─── Extracted Entities ───────────────────────────────────────────────────────
// Stores preprocessed signals extracted from emails before classification.
// These are the raw signals the classification agent uses.

model ExtractedEntity {
  id                  String   @id @default(cuid())
  claimId             String
  claim               Claim    @relation(fields: [claimId], references: [id])
  possibleClaimNumber String?  // Extracted claim reference
  personNames         String?  // JSON array: ["John Doe", "Jane Smith"]
  dates               String?  // JSON array: ["2024-01-15", "15 Jan 2024"]
  keywords            String?  // JSON array: ["assessment", "motor", "claim"]
  cleanedBody         String?  // Cleaned email body (signatures, disclaimers removed)
  createdAt           DateTime @default(now())
}

model ClaimFeedback {
  id              String   @id @default(cuid())
  claimId         String
  claim           Claim    @relation(fields: [claimId], references: [id])
  feedbackType    String   // "confirmed_correct", "flagged_incorrect", "field_corrected"
  fieldName       String?  // which field was corrected (null = overall confirmation)
  originalValue   String?  // what AI originally extracted
  correctedValue  String?  // what user changed it to
  aiConfidence    Int?     // confidence at time of feedback
  processingStage String?  // stage at time of feedback
  learningSignal  String?  // "increase_weight", "decrease_weight", "neutral"
  reviewedBy      String?  // user identifier who submitted the feedback
  createdAt       DateTime @default(now())
}

model AuditLog {
  id               String   @id @default(cuid())
  claimId          String?
  claim            Claim?   @relation(fields: [claimId], references: [id])
  action           String
  details          String?
  status           String   @default("SUCCESS") // SUCCESS, WARNING, ERROR
  processedBy      String?  // AUTO, MANUAL
  createdAt        DateTime @default(now())
}

model PrintQueueItem {
  id          String   @id @default(cuid())
  claimId     String?
  claim       Claim?   @relation(fields: [claimId], references: [id])
  fileName    String
  filePath    String?
  printStatus String   @default("QUEUED") // QUEUED, PRINTING, COMPLETED, FAILED
  pages       Int?
  createdAt   DateTime @default(now())
  printedAt   DateTime?
  error       String?
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
}

model WorkflowStage {
  id          String   @id @default(cuid())
  stageKey    String   @unique
  label       String
  description String
  icon        String
  color       String
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  config      String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Self-Learning System ────────────────────────────────────────────────────────
// The system learns from user corrections to improve future AI extraction accuracy.
// When a user corrects a field (e.g., client name), a LearningPattern is created
// that is injected into future AI prompts for emails from the same sender domain.

model LearningPattern {
  id                  String   @id @default(cuid())
  senderDomain        String   // email domain that sent the claim (e.g., "santam.co.za")
  insuranceCompanyId  String?
  insuranceCompany    InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  fieldName           String   // which claim field this pattern is for
  patternHint         String   // human-readable hint injected into AI prompt
  exampleOriginal     String?  // what AI originally extracted (before correction)
  exampleCorrected    String?  // what the user corrected it to
  correctionCount     Int      @default(1) // how many times this correction was confirmed
  confidence          Int      @default(50) // derived confidence (more corrections = higher trust)
  lastAppliedAt       DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Strategic Knowledge Base ──────────────────────────────────────────────────
// Stores classified email examples as training data for the AI classifier.
// Each entry represents a historical email classification, optionally corrected by the user.
// The system uses these as few-shot examples in the AI prompt to improve accuracy.

model ClassificationKnowledge {
  id                      String   @id @default(cuid())
  claimId                 String?  // linked claim if one was created
  claim                   Claim?   @relation(fields: [claimId], references: [id])
  senderDomain            String   // email domain (e.g., "santam.co.za")
  senderEmail             String?  // full sender email (masked for privacy)
  subject                 String   // email subject line
  emailHash               String   @unique // SHA-256 of (subject+body) for dedup
  bodySnippet             String?  // first 500 chars of body for context
  originalClassification  String   // what AI classified it as
  correctedClassification String?  // what user corrected it to (null = AI was correct)
  confidence              Int      @default(0) // AI confidence (0-100)
  reasoning               String?  // AI reasoning
  keywords                String?  // JSON: ["assessment", "motor", "follow-up"]
  followUpSignals         String?  // JSON: detected follow-up signals
  isCorrected             Boolean  @default(false) // user corrected the classification
  source                  String   @default("auto") // "auto" | "corrected" | "manual"
  isActive                Boolean  @default(true) // can be disabled
  referenceCount          Int      @default(0) // how many times used in prompts
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─── Sender Pattern Database ──────────────────────────────────────────────────
// Stores learned patterns for each sender domain to improve classification speed.
// Automatically updated from classification history. Used for fast pre-screening
// before invoking the AI classifier.

model SenderPattern {
  id                      String   @id @default(cuid())
  senderDomain            String   @unique // email domain
  insuranceCompanyId      String?
  insuranceCompany        InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  // Classification statistics per sender
  totalEmails             Int      @default(0)
  newClaimCount           Int      @default(0)
  followUpCount           Int      @default(0)
  missingInfoCount        Int      @default(0)
  ignoreCount             Int      @default(0)
  otherCount              Int      @default(0)
  correctedCount          Int      @default(0) // how many times AI was wrong for this sender
  // Learned patterns
  typicalSubjectPatterns  String?  // JSON: common subject line patterns
  claimNumberRegex        String?  // regex pattern for claim numbers from this sender
  classificationHints     String?  // JSON: characteristic phrases and their typical classification
  newClaimIndicators      String?  // JSON: phrases that strongly indicate new claims from this sender
  followUpIndicators      String?  // JSON: phrases that strongly indicate follow-ups from this sender
  // Performance metrics
  accuracyRate            Float    @default(0) // percentage of correct classifications
  avgConfidence           Float    @default(0) // average AI confidence for this sender
  lastSeenAt              DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
