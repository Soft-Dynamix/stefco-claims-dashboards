// STEFCO Claims Dashboard - Complete Database Schema
// Version 1.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CORE MODELS
// =============================================================================

/// Insurance company registry with domain mappings
model InsuranceCompany {
  id            String   @id @default(cuid())
  name          String   @unique
  shortName     String?
  folderName    String   // Folder name for file organization
  senderDomains String?  // JSON array of sender email domains
  contactEmail  String?
  contactPhone  String?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claims        Claim[]
  learningPatterns LearningPattern[]
  classificationKnowledge ClassificationKnowledge[]
  extractionPatterns ExtractionPattern[]

  @@map("insurance_companies")
}

/// Central claim record with all extracted and user-verified data
model Claim {
  id                    String   @id @default(cuid())
  claimNumber           String   @unique
  clientName            String?
  clientEmail           String?
  clientPhone           String?
  claimType             String?  // MOTOR, PROPERTY, LIABILITY, etc.
  incidentDate          DateTime?
  incidentDescription   String?
  vehicleRegistration   String?
  vehicleMake           String?
  vehicleModel          String?
  propertyAddress       String?
  excessAmount          Float?
  status                String   @default("NEW") // NEW, IN_PROGRESS, PENDING_INFO, COMPLETED, CLOSED
  processingStage       String   @default("INTAKE") // INTAKE, CLASSIFIED, EXTRACTED, REVIEWED, PROCESSED, ARCHIVED
  
  // AI confidence scores
  classificationConfidence Float?
  extractionConfidence     Float?
  
  // Source tracking
  sourceEmailId        String?
  sourceEmailSubject   String?
  sourceEmailFrom      String?
  sourceEmailDate      DateTime?
  
  // Relationships
  insuranceCompanyId   String?
  insuranceCompany     InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  
  // Processing metadata
  processedBy          String?  // AUTO or user ID
  processedAt          DateTime?
  reviewedBy           String?
  reviewedAt           DateTime?
  
  // Timestamps
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  feedback             ClaimFeedback[]
  notes                ClaimNote[]
  auditLogs            AuditLog[]
  printQueueItems      PrintQueueItem[]

  @@index([claimNumber])
  @@index([status])
  @@index([insuranceCompanyId])
  @@map("claims")
}

/// Claim notes for internal communication
model ClaimNote {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  content   String
  createdBy String?
  createdAt DateTime @default(now())

  @@map("claim_notes")
}

/// User feedback on claim accuracy
model ClaimFeedback {
  id              String   @id @default(cuid())
  claimId         String
  claim           Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  feedbackType    String   // confirmed, flagged, corrected
  fieldName       String?  // Which field was corrected
  originalValue   String?  // AI extracted value
  correctedValue  String?  // User corrected value
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())

  @@map("claim_feedback")
}

/// Structured feedback when emails are rejected/ignored
model RejectionFeedback {
  id                String   @id @default(cuid())
  emailQueueId      String
  
  // Classification at time of rejection
  originalClassification  String?  // What AI thought
  originalConfidence     Float?
  
  // Why it was rejected
  rejectionCategory String   // duplicate, follow_up, spam, marketing, wrong_sender, not_a_claim, already_processed, test_email, other
  rejectionReason   String?  // Free text explanation
  
  // Thread detection info
  isFollowUp        Boolean  @default(false)
  relatedClaimId    String?  // If this was a follow-up to existing claim
  threadSubject     String?  // Normalized subject for thread matching
  
  // Learning hints for future
  suggestedRule     String?  // e.g., "Ignore 'Re:' emails from this sender"
  applyToSender     Boolean  @default(false)  // Create ignore rule for sender?
  
  // Metadata
  emailSubject      String?
  emailFrom         String?
  emailFromDomain   String?
  
  createdBy         String?
  createdAt         DateTime @default(now())

  @@index([rejectionCategory])
  @@index([emailFromDomain])
  @@map("rejection_feedback")
}

/// Thread detection patterns - learned from follow-up emails
model ThreadPattern {
  id                String   @id @default(cuid())
  senderDomain      String
  
  // Pattern details
  subjectPrefix     String?  // e.g., "Re:", "FWD:", "RE:"
  normalizedSubject String?  // Subject without prefixes
  
  // How often this pattern indicates follow-up
  followUpCount     Int      @default(0)
  newClaimCount     Int      @default(0)
  isFollowUpProbability Float @default(0)
  
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([senderDomain, normalizedSubject])
  @@map("thread_patterns")
}

// =============================================================================
// EMAIL PROCESSING MODELS
// =============================================================================

/// Emails awaiting processing or human review
model EmailQueue {
  id                String   @id @default(cuid())
  messageId         String   @unique  // SHA-256 hash of subject + body
  
  // Email content
  subject           String?
  from              String?
  fromDomain        String?
  to                String?
  bodyText          String?
  bodyHtml          String?
  
  // Attachments info
  attachments       String?  // JSON array of attachment metadata
  
  // AI analysis results
  aiClassification  String?  // NEW_CLAIM, IGNORE, MISSING_INFO, OTHER
  aiConfidence      Float?
  aiReasoning       String?
  aiExtractedData   String?  // JSON of extracted fields
  
  // Processing status
  status            String   @default("PENDING") // PENDING, AI_ANALYZED, USER_REVIEWING, CLAIM_CREATED, IGNORED
  processingRoute   String?  // auto_create, ai_suggest, manual_review
  
  // Learning hints applied
  learningHintsCount Int     @default(0)
  
  // Result tracking
  createdClaimId    String?
  ignoreReason      String?
  ignoreCategory    String?
  
  // Timestamps
  emailDate         DateTime?
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  
  // Relationships
  predictions       Prediction[]

  @@index([status])
  @@index([fromDomain])
  @@map("email_queue")
}

/// Full AI prediction with alternatives and reasoning
model Prediction {
  id                String   @id @default(cuid())
  emailQueueId      String
  emailQueue        EmailQueue @relation(fields: [emailQueueId], references: [id], onDelete: Cascade)
  
  predictedClass    String
  confidence        Float
  alternatives      String?  // JSON array of alternative predictions
  reasoning         String?
  decision          String?  // proceed, review, reject
  
  // Extracted fields
  extractedFields   String?  // JSON of extracted data
  
  // Learning context
  learningHintsCount Int     @default(0)
  senderPatternsCount Int    @default(0)
  
  createdAt         DateTime @default(now())

  @@map("predictions")
}

/// Preprocessed signals from emails
model ExtractedEntity {
  id                    String   @id @default(cuid())
  emailQueueId          String?
  
  // Extracted signals
  possibleClaimNumbers  String?  // JSON array
  personNames           String?  // JSON array
  dates                 String?  // JSON array
  phoneNumbers          String?  // JSON array
  emailAddresses        String?  // JSON array
  keywords              String?  // JSON array
  monetaryAmounts       String?  // JSON array
  addresses             String?  // JSON array
  
  // Metadata
  confidence            Float?
  createdAt             DateTime @default(now())

  @@map("extracted_entities")
}

// =============================================================================
// LEARNING ENGINE MODELS
// =============================================================================

/// Learned extraction patterns per sender domain
model LearningPattern {
  id                String   @id @default(cuid())
  senderDomain      String
  insuranceCompanyId String?
  insuranceCompany  InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  
  // Pattern details
  fieldName         String   // clientName, claimNumber, etc.
  patternHint       String   // Human-readable description
  exampleOriginal   String?  // Example of original extraction
  exampleCorrected  String?  // Example of corrected value
  
  // Confidence scoring
  confidence        Int      @default(55) // 50-95 scale
  correctionCount   Int      @default(1)
  
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([senderDomain, fieldName])
  @@index([senderDomain])
  @@map("learning_patterns")
}

/// Few-shot examples for AI classifier training
model ClassificationKnowledge {
  id                    String   @id @default(cuid())
  senderDomain          String
  subject               String?
  bodySnippet           String?  // First 200 chars or key snippet
  
  originalClassification String?
  correctedClassification String
  
  confidence            Float?
  isActive              Boolean  @default(true)
  
  insuranceCompanyId    String?
  insuranceCompany      InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([senderDomain])
  @@map("classification_knowledge")
}

/// Aggregated statistics per sender domain
model SenderPattern {
  id                String   @id @default(cuid())
  senderDomain      String   @unique
  
  // Statistics
  totalEmails       Int      @default(0)
  newClaimCount     Int      @default(0)
  ignoreCount       Int      @default(0)
  otherCount        Int      @default(0)
  
  // Accuracy tracking
  correctCount      Int      @default(0)
  correctedCount    Int      @default(0)
  accuracyRate      Float    @default(0)
  
  // Automation level
  automationLevel   String   @default("manual") // manual, semi_auto, auto
  
  // Hints for AI
  classificationHints String?  // JSON array of learned hints
  
  // Confidence scoring
  confidenceScore   Float    @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("sender_patterns")
}

/// Sender learning profile for progressive automation
model SenderLearningProfile {
  id                String   @id @default(cuid())
  senderDomain      String   @unique
  
  // Pattern counts
  patternCount      Int      @default(0)
  classificationCount Int    @default(0)
  
  // Accuracy metrics
  correctClassifications Int @default(0)
  totalClassifications    Int @default(0)
  accuracyRate           Float @default(0)
  
  // Automation tier
  automationLevel   String   @default("manual") // manual, semi_auto, auto
  
  // Composite confidence
  confidenceScore   Float    @default(0)
  
  // Timestamps
  lastEmailAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("sender_learning_profiles")
}

/// Auto-ignore rules for non-claim email senders
model SenderIgnoreRule {
  id            String   @id @default(cuid())
  senderDomain  String
  category      String   // spam, marketing, duplicate, wrong_sender, personal, out_of_office, system_notification, other
  reason        String?
  ignoreCount   Int      @default(1)
  isActive      Boolean  @default(true)
  autoIgnore    Boolean  @default(false)  // Auto-ignore after threshold
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([senderDomain, category])
  @@map("sender_ignore_rules")
}

// =============================================================================
// AUTO-DETECTION & SUGGESTION MODELS
// =============================================================================

/// Suggested domain-to-company mappings awaiting review
model DomainSuggestion {
  id                  String   @id @default(cuid())
  senderDomain        String   @unique
  
  // Detected from email content
  detectedCompanyName String?  // Company name found in email signature/content
  detectedFromEmail   String?  // Original email address
  detectedFromName    String?  // Sender display name
  
  // AI suggestion
  suggestedCompanyId  String?  // Link to existing company if match found
  suggestedCompanyName String? // Suggested new company name
  confidenceScore     Float    @default(0)
  
  // Evidence
  emailCount          Int      @default(1)  // How many emails from this domain
  claimCount          Int      @default(0)  // How many claims created
  sampleSubjects      String?  // JSON array of sample email subjects
  
  // Status
  status              String   @default("pending") // pending, approved, rejected, auto_approved
  reviewedBy          String?
  reviewedAt          DateTime?
  
  // Final mapping
  linkedCompanyId     String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@map("domain_suggestions")
}

/// Patterns for auto-detecting insurance companies from domain names
model CompanyDetectionPattern {
  id              String   @id @default(cuid())
  
  // Pattern matching
  domainPattern   String   @unique  // e.g., "*.santam.co.za", "claims.*.com"
  companyNameHint String?  // Regex or hint to extract company name
  
  // Mapping
  insuranceCompanyId String?
  
  // Statistics
  matchCount      Int      @default(0)
  successRate     Float    @default(0)
  
  isActive        Boolean  @default(true)
  autoApprove     Boolean  @default(false)  // Auto-approve if confidence > 90%
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("company_detection_patterns")
}

/// Known insurance company domain patterns (seeded data)
model InsuranceDomainKnowledge {
  id              String   @id @default(cuid())
  domainPattern   String   @unique  // e.g., "santam.co.za", "outsurance.co.za"
  companyName     String   // Official company name
  shortName       String?  // Common short name
  country         String   @default("ZA")  // Country code
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("insurance_domain_knowledge")
}

// =============================================================================
// EXTRACTION PATTERN LEARNING MODELS
// =============================================================================

/// Company-specific extraction patterns for each field type
model ExtractionPattern {
  id                  String   @id @default(cuid())
  insuranceCompanyId  String
  insuranceCompany    InsuranceCompany @relation(fields: [insuranceCompanyId], references: [id])
  
  // What field this pattern extracts
  fieldType           String   // claimNumber, policyNumber, clientName, vehicleReg, excess, etc.
  
  // Pattern definition
  patternType         String   // regex, keyword, position, format
  patternValue        String   // The actual regex or pattern
  
  // Example and description
  description         String?  // Human-readable description
  exampleMatch        String?  // Example of what matches
  
  // Confidence and usage
  confidence          Int      @default(70)  // 50-100
  successCount        Int      @default(0)
  failureCount        Int      @default(0)
  
  // Pattern priority (higher = try first)
  priority            Int      @default(0)
  
  isActive            Boolean  @default(true)
  isSystemPattern     Boolean  @default(false)  // System-generated vs user-taught
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([insuranceCompanyId, fieldType, patternValue])
  @@index([insuranceCompanyId, fieldType])
  @@map("extraction_patterns")
}

/// Sample extractions for teaching the system (few-shot examples)
model ExtractionExample {
  id                  String   @id @default(cuid())
  insuranceCompanyId  String?
  
  // The field being extracted
  fieldType           String   // claimNumber, policyNumber, clientName, etc.
  
  // The sample data
  sourceText          String   // Original text snippet
  extractedValue      String   // What was extracted
  contextBefore       String?  // Text before the match
  contextAfter        String?  // Text after the match
  
  // How it was learned
  learnedFrom         String   // user_correction, initial_extraction, manual_entry
  verified            Boolean  @default(true)
  
  // Email reference
  emailQueueId        String?
  
  createdAt           DateTime @default(now())

  @@index([insuranceCompanyId, fieldType])
  @@map("extraction_examples")
}

/// Claim number format patterns per insurance company
model ClaimNumberFormat {
  id                  String   @id @default(cuid())
  insuranceCompanyId  String
  
  // Format definition
  formatPattern       String   // e.g., "STM-YYYY-NNNNN", "OUT/NNNNNN/YY"
  prefix              String?  // e.g., "STM", "OUT", "CLM"
  separator           String?  // e.g., "-", "/", ""
  
  // Number structure
  hasYear             Boolean  @default(false)
  yearPosition        Int?     // Position of year in format
  numberLength        Int?     // Length of sequential number
  
  // Regex pattern
  regexPattern        String   // Full regex to match
  
  // Example
  example             String?  // Example claim number
  
  // Confidence
  matchCount          Int      @default(0)
  confidence          Int      @default(70)
  
  isActive            Boolean  @default(true)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([insuranceCompanyId, formatPattern])
  @@map("claim_number_formats")
}

// =============================================================================
// SYSTEM MODELS
// =============================================================================

/// Complete audit trail of all system actions
model AuditLog {
  id            String   @id @default(cuid())
  action        String   // claim_created, email_classified, feedback_submitted, etc.
  entityType    String?  // claim, email, pattern, etc.
  entityId      String?
  details       String?  // JSON of action details
  status        String   @default("SUCCESS") // SUCCESS, WARNING, ERROR
  
  // Processing info
  processedBy   String?  // AUTO or user ID
  ipAddress     String?
  userAgent     String?
  
  // Relations
  claimId       String?
  claim         Claim?   @relation(fields: [claimId], references: [id])
  
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Documents queued for printing
model PrintQueueItem {
  id            String   @id @default(cuid())
  claimId       String?
  claim         Claim?   @relation(fields: [claimId], references: [id], onDelete: SetNull)
  
  fileName      String
  filePath      String
  fileType      String?  // pdf, doc, docx, etc.
  
  printStatus   String   @default("QUEUED") // QUEUED, PRINTING, COMPLETED, FAILED
  printedAt     DateTime?
  printedBy     String?
  errorMessage  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([printStatus])
  @@map("print_queue_items")
}

/// Key-value system configuration store
model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

/// Configurable workflow stages
model WorkflowStage {
  id          String   @id @default(cuid())
  stageKey    String   @unique
  label       String
  description String?
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  config      String?  // JSON config for stage behavior
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_stages")
}

// =============================================================================
// ANALYTICS MODELS (Derived/Aggregated)
// =============================================================================

/// Daily statistics snapshot for reporting
model DailyStats {
  id                    String   @id @default(cuid())
  date                  DateTime @unique
  
  // Email stats
  emailsReceived        Int      @default(0)
  emailsClassified      Int      @default(0)
  newClaimsDetected     Int      @default(0)
  emailsIgnored         Int      @default(0)
  
  // Claim stats
  claimsCreated         Int      @default(0)
  claimsCompleted       Int      @default(0)
  claimsPending         Int      @default(0)
  
  // AI accuracy
  correctClassifications Int     @default(0)
  correctedClassifications Int   @default(0)
  avgConfidenceScore    Float    @default(0)
  
  // Processing stats
  autoProcessedCount    Int      @default(0)
  manualReviewCount     Int      @default(0)
  
  createdAt             DateTime @default(now())

  @@index([date])
  @@map("daily_stats")
}
